<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Gift Shop Tools</title>
<style>
* {
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    margin: 0;
    min-height: 100vh;
    background: #f7f4ee;
    color: #1f2933;
}

.top {
    padding: 28px 20px 18px;
    background: #ffffff;
    border-bottom: 1px solid #e6dfd3;
}

h1 {
    margin: 0;
    font-size: 28px;
}

.subtitle {
    margin-top: 8px;
    color: #667085;
    font-size: 15px;
}

.wrap {
    padding: 18px;
    max-width: 720px;
    margin: 0 auto;
}

.tool {
    display: block;
    text-decoration: none;
    background: #ffffff;
    border: 1px solid #e0d8cc;
    border-radius: 8px;
    padding: 18px;
    margin-bottom: 14px;
    color: inherit;
    box-shadow: 0 2px 8px rgba(31, 41, 51, 0.06);
}

.tool:active {
    transform: scale(0.99);
}

.tool-title {
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 7px;
}

.tool-desc {
    color: #667085;
    line-height: 1.4;
}

.arrow {
    float: right;
    font-size: 24px;
    color: #b42318;
}
</style>
</head>
<body>
<div class="top">
    <h1>Gift Shop Tools</h1>
    <div class="subtitle">Choose the calculator you want to use.</div>
</div>

<main class="wrap">
    <a class="tool" href="giftshop_price_tool.html">
        <span class="arrow">›</span>
        <div class="tool-title">Gift Shop Price Tool</div>
        <div class="tool-desc">Calculate selling prices, create secret purchase codes, and decode them.</div>
    </a>

    <a class="tool" href="weight_price_calculator.html">
        <span class="arrow">›</span>
        <div class="tool-title">Weight Price Calculator</div>
        <div class="tool-desc">Calculate item price from rate per KG and weight in grams or kilograms.</div>
    </a>
</main>
</body>
</html>
